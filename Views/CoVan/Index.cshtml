@{
    ViewData["Title"] = "Dashboard giảng viên";
}

<main class="role-dashboard">
    <aside class="role-sidebar">
        <a class="role-brand" asp-controller="Home" asp-action="Index">StudyConnect</a>
        <p>Giảng viên / Cố vấn</p>
        <a class="active" href="#tong-quan">Tổng quan</a>
        <a href="#duyet-mentor">Duyệt mentor</a>
        <a href="#chat-luong">Chất lượng học tập</a>
        <a asp-controller="TaiKhoans" asp-action="Profile">Hồ sơ cá nhân</a>
    </aside>

    <section class="role-main">
        <header class="role-header">
            <div>
                <p class="eyebrow">Đúng vai trò: Giảng viên / Cố vấn</p>
                <h1>Theo dõi chất lượng hỗ trợ học tập</h1>
                <span>Duyệt chuyên môn mentor, theo dõi báo cáo buổi học và thống kê chất lượng học tập 1-1.</span>
            </div>
            <form asp-controller="TaiKhoans" asp-action="Logout" method="post"><button class="btn btn-outline">Đăng xuất</button></form>
        </header>

        <section class="role-stats" id="tong-quan">
            <article><small>Hồ sơ chờ duyệt</small><strong>@ViewBag.HoSoChoDuyet</strong></article>
            <article><small>Mentor đang có</small><strong>@ViewBag.Mentor</strong></article>
            <article><small>Yêu cầu học tập</small><strong>@ViewBag.YeuCau</strong></article>
            <article><small>Báo cáo buổi học</small><strong>@ViewBag.BaoCao</strong></article>
            <article><small>Đánh giá</small><strong>@ViewBag.DanhGia</strong></article>
        </section>

        <section class="role-panel" id="duyet-mentor">
            <div class="role-panel-head"><h2>Duyệt chuyên môn mentor</h2></div>
            <div class="role-feature-grid">
                <article><span>01</span><h3>Xem hồ sơ đăng ký mentor</h3><p>Kiểm tra lĩnh vực hướng dẫn, điểm môn/GPA, kỹ năng, kinh nghiệm và minh chứng.</p></article>
                <article><span>02</span><h3>Duyệt hoặc từ chối</h3><p>Đánh giá năng lực chuyên môn; yêu cầu bổ sung minh chứng nếu hồ sơ chưa đủ.</p></article>
                <article><span>03</span><h3>Theo dõi thống kê mentor</h3><p>Xem đánh giá, điểm uy tín, tỷ lệ hoàn thành và phản hồi từ sinh viên.</p></article>
            </div>
        </section>

        <section class="role-panel" id="chat-luong">
            <div class="role-panel-head"><h2>Phạm vi quyền hạn</h2></div>
            <div class="role-note-list">
                <p>Giảng viên/Cố vấn không xét duyệt Phó chủ nhiệm CLB và không can thiệp quy trình bầu cử nội bộ CLB.</p>
                <p>Vai trò này tập trung vào chất lượng học tập, duyệt chuyên môn mentor và báo cáo tổng hợp hỗ trợ học tập 1-1.</p>
            </div>
        </section>
    </section>
</main>
