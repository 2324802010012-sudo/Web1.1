@using StudyConnect.Models
@using StudyConnect.ViewModels
@{
    ViewData["Title"] = "Dashboard cố vấn";
    var mentors = ViewBag.ManagedMentors as List<ManagedMentorViewModel> ?? [];
    var pendingApplications = ViewBag.PendingMentorApplications as List<DangKyHuongDan> ?? [];
    var notifications = ViewBag.Notifications as List<DashboardNotificationViewModel> ?? [];
}

<main class="role-dashboard">
    <aside class="role-sidebar">
        <a class="role-brand" asp-controller="Home" asp-action="Index">StudyConnect</a>
        <p>Giảng viên / Cố vấn</p>
        <a class="active" href="#tong-quan">Tổng quan</a>
        <a href="#thong-bao">Thông báo</a>
        <a href="#duyet-mentor">Duyệt mentor</a>
        <a href="#mentor-quan-ly">Mentor quản lý</a>
        <a asp-controller="TaiKhoans" asp-action="Profile">Hồ sơ cá nhân</a>
    </aside>

    <section class="role-main">
        <header class="role-header">
            <div>
                <p class="eyebrow">Đúng vai trò: Giảng viên / Cố vấn</p>
                <h1>Theo dõi chất lượng hỗ trợ học tập</h1>
                <span>Duyệt hồ sơ sinh viên đăng ký làm mentor, quản lý mentor và theo dõi chất lượng học tập 1-1.</span>
            </div>
            <form asp-controller="TaiKhoans" asp-action="Logout" method="post"><button class="btn btn-outline" type="submit">Đăng xuất</button></form>
        </header>

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="flow-alert success">@success</div>
        }

        <section class="role-stats" id="tong-quan">
            <article><small>Hồ sơ chờ duyệt</small><strong>@ViewBag.HoSoChoDuyet</strong></article>
            <article><small>Mentor đang quản lý</small><strong>@ViewBag.Mentor</strong></article>
            <article><small>Yêu cầu học tập</small><strong>@ViewBag.YeuCau</strong></article>
            <article><small>Buổi học hoàn thành</small><strong>@ViewBag.BuoiHocHoanThanh</strong></article>
            <article><small>Đánh giá</small><strong>@ViewBag.DanhGia</strong></article>
        </section>

        <section class="role-feature-grid compact">
            <article><span>HD</span><h3>@ViewBag.MentorHoatDong mentor hoạt động</h3><p>Mentor có thể nhận ghép nối và xuất hiện trong gợi ý học 1-1.</p></article>
            <article><span>CT</span><h3>@ViewBag.MentorCanChuY mentor cần chú ý</h3><p>Mentor tạm dừng, thiếu lịch rảnh hoặc có đánh giá thấp cần cố vấn rà soát.</p></article>
            <article><span>DV</span><h3>Duyệt chuyên môn</h3><p>Kiểm tra điểm môn, minh chứng, lịch rảnh và năng lực hỗ trợ trước khi duyệt.</p></article>
        </section>

        <section class="role-panel" id="thong-bao">
            <div class="role-panel-head"><h2>Thông báo cần xử lý</h2><strong>@notifications.Count</strong></div>
            <div class="dashboard-notification-list">
                @if (notifications.Count == 0)
                {
                    <article><strong>Không có thông báo mới</strong><p>Đơn đăng ký mentor mới sẽ hiển thị tại đây.</p></article>
                }
                else
                {
                    @foreach (var item in notifications)
                    {
                        <article class="@item.Tone">
                            <strong>@item.Title</strong>
                            <p>@item.Message</p>
                            @if (!string.IsNullOrWhiteSpace(item.Url))
                            {
                                <a href="@item.Url">Xem chi tiết</a>
                            }
                        </article>
                    }
                }
            </div>
        </section>

        <section class="role-panel" id="duyet-mentor">
            <div class="role-panel-head">
                <div>
                    <p class="eyebrow">Đăng ký làm mentor</p>
                    <h2>Hồ sơ chờ cố vấn duyệt</h2>
                </div>
                <strong>@pendingApplications.Count hồ sơ</strong>
            </div>

            @if (pendingApplications.Count == 0)
            {
                <div class="empty-state"><h3>Không có hồ sơ chờ duyệt</h3><p>Khi sinh viên gửi đăng ký làm mentor, hồ sơ sẽ xuất hiện tại đây.</p></div>
            }
            else
            {
                <div class="mentor-application-list">
                    @foreach (var item in pendingApplications)
                    {
                        <article>
                            <div>
                                <span class="status-pill">@item.TrangThaiDuyet</span>
                                <h3>@item.MaSinhVienNavigation.MaTaiKhoanNavigation.HoTen</h3>
                                <p>@item.MaLinhVucNavigation.TenLinhVuc - Điểm môn: @(item.DiemMon?.ToString("0.0") ?? "Chưa nhập")</p>
                            </div>
                            <a class="btn btn-primary" asp-action="DangKyMentorDetails" asp-route-id="@item.MaDangKy">Xem chi tiết</a>
                        </article>
                    }
                </div>
            }
        </section>

        <section class="role-panel" id="mentor-quan-ly">
            <div class="role-panel-head">
                <div>
                    <p class="eyebrow">Quản lý bởi cố vấn</p>
                    <h2>Danh sách toàn bộ mentor</h2>
                    <span class="panel-note">Điểm uy tín tự động: 70% đánh giá thật, 20% buổi hoàn thành, 10% số lượt đánh giá.</span>
                </div>
                <strong>@mentors.Count mentor</strong>
            </div>

            @if (mentors.Count == 0)
            {
                <div class="empty-state"><h3>Chưa có mentor</h3><p>Khi cố vấn duyệt mentor, danh sách sẽ hiển thị tại đây.</p></div>
            }
            else
            {
                <div class="managed-mentor-table advisor-mentor-table">
                    <div class="managed-mentor-head"><span>Mentor</span><span>Chuyên môn & tải</span><span>Chất lượng</span><span>Quản lý</span></div>
                    @foreach (var mentor in mentors)
                    {
                        <form asp-action="UpdateMentor" method="post">
                            <input type="hidden" name="id" value="@mentor.MaHuongDan" />
                            <strong>
                                @mentor.HoTen
                                <small>@mentor.Email</small>
                                <small>@mentor.LoaiNguoiHuongDan</small>
                            </strong>
                            <span>
                                @(string.IsNullOrWhiteSpace(mentor.ChuyenMon) ? "Chưa cập nhật chuyên môn" : mentor.ChuyenMon)
                                <small>@mentor.SoGhepNoi ghép nối • @mentor.SoBuoiHoc buổi học • @mentor.SoKhungLichRanh khung lịch rảnh</small>
                            </span>
                            <span class="advisor-quality-box">
                                <b>Hạng #@mentor.ThuHang • Uy tín @mentor.DiemUyTin.ToString("0.00")</b>
                                <b>@mentor.DiemDanhGia.ToString("0.0") sao (@mentor.SoLuotDanhGia đánh giá)</b>
                                <small>@mentor.SoBuoiHoanThanh buổi hoàn thành • @mentor.SoLuotDanhGia lượt đánh giá</small>
                                <small class="reputation-formula">@mentor.CongThucUyTin</small>
                            </span>
                            <div class="advisor-mentor-actions">
                                <select name="trangThai">
                                    <option selected="@(mentor.TrangThai == "Hoạt động")">Hoạt động</option>
                                    <option selected="@(mentor.TrangThai == "Tạm dừng")">Tạm dừng</option>
                                    <option selected="@(mentor.TrangThai == "Cần theo dõi")">Cần theo dõi</option>
                                </select>
                                <input name="loaiNguoiHuongDan" maxlength="50" value="@mentor.LoaiNguoiHuongDan" />
                                <small class="readonly-score">Uy tín không sửa tay, được tính lại từ dữ liệu thật.</small>
                                <div>
                                    <a class="btn btn-light" asp-controller="Home" asp-action="MentorDetail" asp-route-id="@mentor.MaHuongDan">Hồ sơ</a>
                                    <button class="btn btn-primary" type="submit">Lưu</button>
                                </div>
                            </div>
                        </form>
                    }
                </div>
            }
        </section>
    </section>
</main>
