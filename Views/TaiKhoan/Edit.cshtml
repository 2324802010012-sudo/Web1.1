@model StudyConnect.ViewModels.TaiKhoanEditViewModel
@{
    ViewData["Title"] = "Sửa tài khoản";
}

<section class="admin-page narrow">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Quản trị hệ thống</p>
            <h1>Sửa tài khoản</h1>
        </div>
        <a class="btn btn-light" asp-action="Index">Quay lại</a>
    </div>

    <div class="form-card">
        <form asp-action="Edit" asp-route-id="@Model.MaTaiKhoan" method="post" class="form-stack">
            <div asp-validation-summary="ModelOnly" class="alert error"></div>
            <input type="hidden" asp-for="MaTaiKhoan" />
            <div class="form-grid two">
                <label class="form-field">
                    <span>Họ tên</span>
                    <input asp-for="HoTen" />
                    <small asp-validation-for="HoTen"></small>
                </label>
                <label class="form-field">
                    <span>Email</span>
                    <input asp-for="Email" />
                    <small asp-validation-for="Email"></small>
                </label>
                <label class="form-field">
                    <span>Số điện thoại</span>
                    <input asp-for="SoDienThoai" />
                    <small asp-validation-for="SoDienThoai"></small>
                </label>
                <label class="form-field">
                    <span>Vai trò</span>
                    <select asp-for="VaiTro" asp-items="ViewBag.RoleOptions"></select>
                    <small asp-validation-for="VaiTro"></small>
                </label>
                <label class="form-field">
                    <span>Trạng thái</span>
                    <select asp-for="TrangThai" asp-items="ViewBag.StatusOptions"></select>
                    <small asp-validation-for="TrangThai"></small>
                </label>
                <label class="form-field">
                    <span>Mật khẩu mới</span>
                    <input asp-for="MatKhauMoi" placeholder="Để trống nếu không đổi" />
                    <small asp-validation-for="MatKhauMoi"></small>
                </label>
            </div>
            <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
        </form>
    </div>
</section>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
