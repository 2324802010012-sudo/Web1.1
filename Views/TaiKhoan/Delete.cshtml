@model StudyConnect.Models.TaiKhoan
@using StudyConnect.ViewModels
@{
    ViewData["Title"] = "Xóa tài khoản";
}

<section class="admin-page narrow">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Quản trị hệ thống</p>
            <h1>Xóa tài khoản</h1>
        </div>
        <a class="btn btn-light" asp-action="Index">Quay lại</a>
    </div>

    <div class="detail-card danger-zone">
        <h2>Bạn chắc chắn muốn xóa tài khoản này?</h2>
        <dl>
            <dt>Họ tên</dt><dd>@Model.HoTen</dd>
            <dt>Email</dt><dd>@Model.Email</dd>
            <dt>Vai trò</dt><dd>@AccountRoles.DisplayName(Model.VaiTro)</dd>
            <dt>Trạng thái</dt><dd>@(Model.TrangThai ?? "-")</dd>
        </dl>
        <form asp-action="Delete" asp-route-id="@Model.MaTaiKhoan" method="post" class="row-actions">
            <input type="hidden" asp-for="MaTaiKhoan" />
            <button class="btn btn-danger" type="submit">Xóa tài khoản</button>
            <a class="btn btn-light" asp-action="Index">Hủy</a>
        </form>
    </div>
</section>
