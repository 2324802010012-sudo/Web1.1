@model StudyConnect.Models.TaiKhoan
@using StudyConnect.ViewModels
@{
    ViewData["Title"] = "Chi tiết tài khoản";
}

<section class="admin-page narrow">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Tài khoản</p>
            <h1>@Model.HoTen</h1>
        </div>
        <a class="btn btn-light" asp-action="Index">Quay lại</a>
    </div>

    <div class="detail-card">
        <dl>
            <dt>Email</dt><dd>@Model.Email</dd>
            <dt>Vai trò</dt><dd>@AccountRoles.DisplayName(Model.VaiTro)</dd>
            <dt>Số điện thoại</dt><dd>@(Model.SoDienThoai ?? "-")</dd>
            <dt>Trạng thái</dt><dd>@(Model.TrangThai ?? "-")</dd>
            <dt>Ngày tạo</dt><dd>@Model.NgayTao?.ToString("dd/MM/yyyy HH:mm")</dd>
        </dl>
        <div class="row-actions">
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.MaTaiKhoan">Sửa tài khoản</a>
            <a class="btn btn-light" asp-action="Profile">Hồ sơ của tôi</a>
        </div>
    </div>
</section>
