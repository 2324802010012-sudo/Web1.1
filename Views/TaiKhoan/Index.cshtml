@model IEnumerable<StudyConnect.Models.TaiKhoan>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.HoTen)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MatKhau)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.VaiTro)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SoDienThoai)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.AnhDaiDien)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TrangThai)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NgayTao)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.GiangVien)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.HoatDongClbs)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LichRanhs)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.NguoiHuongDan)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.SinhVien)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TaiLieuClbs)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ThongBaos)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.HoTen)
            </td>
            <td>
                @Html.DisplayFor(model => item.Email)
            </td>
            <td>
                @Html.DisplayFor(model => item.MatKhau)
            </td>
            <td>
                @Html.DisplayFor(model => item.VaiTro)
            </td>
            <td>
                @Html.DisplayFor(model => item.SoDienThoai)
            </td>
            <td>
                @Html.DisplayFor(model => item.AnhDaiDien)
            </td>
            <td>
                @Html.DisplayFor(model => item.TrangThai)
            </td>
            <td>
                @Html.DisplayFor(model => item.NgayTao)
            </td>
            <td>
                @Html.DisplayFor(model => item.GiangVien)
            </td>
            <td>
                @Html.DisplayFor(model => item.HoatDongClbs)
            </td>
            <td>
                @Html.DisplayFor(model => item.LichRanhs)
            </td>
            <td>
                @Html.DisplayFor(model => item.NguoiHuongDan)
            </td>
            <td>
                @Html.DisplayFor(model => item.SinhVien)
            </td>
            <td>
                @Html.DisplayFor(model => item.TaiLieuClbs)
            </td>
            <td>
                @Html.DisplayFor(model => item.ThongBaos)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.MaTaiKhoan">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.MaTaiKhoan">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.MaTaiKhoan">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
