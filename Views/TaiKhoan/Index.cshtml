@model IEnumerable<StudyConnect.Models.TaiKhoan>
@using StudyConnect.ViewModels
@{
    ViewData["Title"] = "Quản lý tài khoản";
}

<section class="admin-page">
    <div class="page-heading">
        <div>
            <p class="eyebrow">Quản trị hệ thống</p>
            <h1>Quản lý tài khoản</h1>
        </div>
        <a class="btn btn-primary" asp-action="Create">Tạo tài khoản</a>
    </div>

    @if (TempData["SuccessMessage"] is string successMessage)
    {
        <div class="alert success">@successMessage</div>
    }
    @if (TempData["ErrorMessage"] is string errorMessage)
    {
        <div class="alert error">@errorMessage</div>
    }

    <div class="table-card">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Họ tên</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Điện thoại</th>
                    <th>Trạng thái</th>
                    <th>Ngày tạo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.HoTen</strong></td>
                    <td>@item.Email</td>
                    <td><span class="role-badge">@AccountRoles.DisplayName(item.VaiTro)</span></td>
                    <td>@(item.SoDienThoai ?? "-")</td>
                    <td>@(item.TrangThai ?? "-")</td>
                    <td>@item.NgayTao?.ToString("dd/MM/yyyy")</td>
                    <td class="table-actions">
                        <a asp-action="Details" asp-route-id="@item.MaTaiKhoan">Chi tiết</a>
                        <a asp-action="Edit" asp-route-id="@item.MaTaiKhoan">Sửa</a>
                        <a class="danger" asp-action="Delete" asp-route-id="@item.MaTaiKhoan">Xóa</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>
