@model StudyConnect.Models.LinhVucHocTap

@{
    ViewData["Title"] = "Thêm lĩnh vực";
}

<main class="admin-page narrow">
    <header class="page-heading">
        <div>
            <p class="eyebrow">Dữ liệu nền học 1-1</p>
            <h1>Thêm lĩnh vực học tập</h1>
            <p class="muted-copy">Lĩnh vực rõ ràng giúp hệ thống gợi ý mentor đúng chuyên môn hơn.</p>
        </div>
    </header>

    <form asp-action="Create" method="post" class="form-card form-stack">
        <div asp-validation-summary="ModelOnly" class="alert error"></div>

        <label class="form-field">
            <span>Tên lĩnh vực</span>
            <input asp-for="TenLinhVuc" maxlength="100" placeholder="Ví dụ: Cơ sở dữ liệu" />
            <small asp-validation-for="TenLinhVuc"></small>
        </label>

        <label class="form-field">
            <span>Mô tả</span>
            <textarea asp-for="MoTa" rows="5" placeholder="Phạm vi kiến thức, công nghệ, môn học hoặc kỹ năng liên quan"></textarea>
            <small asp-validation-for="MoTa"></small>
        </label>

        <label class="form-field">
            <span>Trạng thái</span>
            <select asp-for="TrangThai" asp-items="ViewBag.StatusOptions"></select>
            <small asp-validation-for="TrangThai"></small>
        </label>

        <div class="row-actions">
            <button class="btn btn-primary" type="submit">Tạo lĩnh vực</button>
            <a class="btn btn-light" asp-action="Index">Quay lại</a>
        </div>
    </form>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
