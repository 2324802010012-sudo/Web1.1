@model StudyConnect.Models.LinhVucHocTap

@{
    ViewData["Title"] = "Cập nhật lĩnh vực";
}

<main class="admin-page narrow">
    <header class="page-heading">
        <div>
            <p class="eyebrow">Dữ liệu nền học 1-1</p>
            <h1>Cập nhật lĩnh vực học tập</h1>
            <p class="muted-copy">Thay đổi này ảnh hưởng đến danh sách chọn khi tạo yêu cầu và hồ sơ mentor.</p>
        </div>
    </header>

    <form asp-action="Edit" asp-route-id="@Model.MaLinhVuc" method="post" class="form-card form-stack">
        <input type="hidden" asp-for="MaLinhVuc" />
        <div asp-validation-summary="ModelOnly" class="alert error"></div>

        <label class="form-field">
            <span>Tên lĩnh vực</span>
            <input asp-for="TenLinhVuc" maxlength="100" />
            <small asp-validation-for="TenLinhVuc"></small>
        </label>

        <label class="form-field">
            <span>Mô tả</span>
            <textarea asp-for="MoTa" rows="5"></textarea>
            <small asp-validation-for="MoTa"></small>
        </label>

        <label class="form-field">
            <span>Trạng thái</span>
            <select asp-for="TrangThai" asp-items="ViewBag.StatusOptions"></select>
            <small asp-validation-for="TrangThai"></small>
        </label>

        <div class="row-actions">
            <button class="btn btn-primary" type="submit">Lưu thay đổi</button>
            <a class="btn btn-light" asp-action="Details" asp-route-id="@Model.MaLinhVuc">Chi tiết</a>
            <a class="btn btn-light" asp-action="Index">Quay lại</a>
        </div>
    </form>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
