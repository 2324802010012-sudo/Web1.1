@model StudyConnect.Models.CauLacBo

@{
    ViewData["Title"] = "Thêm CLB";
}

<main class="admin-page narrow">
    <header class="page-heading">
        <div>
            <p class="eyebrow">Cộng đồng CLB</p>
            <h1>Thêm câu lạc bộ</h1>
            <p class="muted-copy">CLB là lớp dữ liệu cộng đồng hỗ trợ học 1-1, tài liệu và uy tín mentor.</p>
        </div>
    </header>

    <form asp-action="Create" method="post" class="form-card form-stack">
        <div asp-validation-summary="ModelOnly" class="alert error"></div>

        <label class="form-field">
            <span>Tên CLB</span>
            <input asp-for="TenClb" maxlength="150" placeholder="Ví dụ: AI Club" />
            <small asp-validation-for="TenClb"></small>
        </label>

        <label class="form-field">
            <span>Mô tả</span>
            <textarea asp-for="MoTa" rows="5" placeholder="Mục tiêu, nhóm thành viên, hoạt động chính của CLB"></textarea>
            <small asp-validation-for="MoTa"></small>
        </label>

        <div class="form-grid two">
            <label class="form-field">
                <span>Ngày thành lập</span>
                <input asp-for="NgayThanhLap" type="date" />
                <small asp-validation-for="NgayThanhLap"></small>
            </label>
            <label class="form-field">
                <span>Trạng thái</span>
                <select asp-for="TrangThai" asp-items="ViewBag.StatusOptions"></select>
                <small asp-validation-for="TrangThai"></small>
            </label>
        </div>

        <div class="row-actions">
            <button class="btn btn-primary" type="submit">Tạo CLB</button>
            <a class="btn btn-light" asp-action="Index">Quay lại</a>
        </div>
    </form>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
