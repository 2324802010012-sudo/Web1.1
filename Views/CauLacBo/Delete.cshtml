@model StudyConnect.Models.CauLacBo

@{
    ViewData["Title"] = "Tạm dừng hoặc xóa CLB";
    var relatedCount = Model.ThanhVienClbs.Count + Model.HoatDongClbs.Count + Model.TaiLieuClbs.Count + Model.DotDeCuPhoChuNhiems.Count;
}

<main class="admin-page narrow">
    <header class="page-heading">
        <div>
            <p class="eyebrow">Cộng đồng CLB</p>
            <h1>Tạm dừng hoặc xóa CLB</h1>
            <p class="muted-copy">Nếu CLB đã có thành viên, hoạt động, tài liệu hoặc đợt bầu chọn, hệ thống sẽ chuyển sang trạng thái Tạm dừng để giữ lịch sử.</p>
        </div>
    </header>

    <section class="detail-card danger-zone">
        <h2>@Model.TenClb</h2>
        <dl>
            <dt>Trạng thái hiện tại</dt><dd>@(Model.TrangThai ?? "Hoạt động")</dd>
            <dt>Dữ liệu liên quan</dt><dd>@relatedCount mục</dd>
            <dt>Hành động</dt><dd>@(relatedCount > 0 ? "Chuyển sang Tạm dừng" : "Xóa khỏi hệ thống")</dd>
        </dl>

        <form asp-action="Delete" method="post" class="row-actions">
            <input type="hidden" name="id" value="@Model.MaClb" />
            <button type="submit" class="btn btn-danger">Xác nhận</button>
            <a class="btn btn-light" asp-action="Details" asp-route-id="@Model.MaClb">Quay lại chi tiết</a>
        </form>
    </section>
</main>
