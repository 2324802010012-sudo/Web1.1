@model StudyConnect.ViewModels.Hoc11ViewModel
@{
    ViewData["Title"] = "Học 1-1";
}

<header class="site-header">
    <a class="brand" asp-controller="Home" asp-action="Index" aria-label="StudyConnect trang chủ">
        <span class="brand-icon"><span></span><span></span><span></span></span>
        <span><strong>StudyConnect</strong><small>Học 1-1 - Kết nối - Phát triển</small></span>
    </a>

    <nav class="main-nav" aria-label="Điều hướng chính">
        <a asp-controller="Home" asp-action="Index">Trang chủ</a>
        <a class="active" asp-controller="Home" asp-action="Hoc11">Học 1-1</a>
        <a asp-controller="Home" asp-action="CauLacBo">Cộng đồng CLB</a>
    </nav>

    <div class="header-actions">
        <form class="search-box" asp-controller="Home" asp-action="Hoc11" method="get" aria-label="Tìm kiếm mentor">
            <input type="search" name="keyword" value="@Model.Keyword" placeholder="Tìm mentor, kỹ năng..." />
            <button type="submit" aria-label="Tìm kiếm">Tìm</button>
        </form>
        @if (Context.Session.GetInt32("UserId").HasValue)
        {
            <a class="btn btn-light" asp-controller="TaiKhoans" asp-action="Profile">Hồ sơ</a>
            <form asp-controller="TaiKhoans" asp-action="Logout" method="post" class="inline-form">
                <button class="btn btn-primary" type="submit">Đăng xuất</button>
            </form>
        }
        else
        {
            <a class="btn btn-light" asp-controller="TaiKhoans" asp-action="Login">Đăng nhập</a>
            <a class="btn btn-primary" asp-controller="TaiKhoans" asp-action="Create">Đăng ký</a>
        }
    </div>
</header>

<main class="one-page">
    <section class="one-hero">
        <div class="one-hero-inner">
            <div class="one-hero-copy">
                <p class="pill">Quy trình hỗ trợ học tập 1-1</p>
                <h1>Học đúng nhu cầu<br /><span>Cùng mentor phù hợp</span></h1>
                <p>Đăng nhập, cập nhật hồ sơ học tập và lịch rảnh, tạo yêu cầu hỗ trợ, chọn mentor, lên lịch học và đánh giá sau buổi học.</p>
                <div class="one-hero-actions">
                    <a class="btn btn-primary btn-large" asp-controller="YeuCauHoTroHocTaps" asp-action="Create">Tạo yêu cầu hỗ trợ</a>
                    <a class="btn btn-light btn-large" href="#mentor-goi-y">Tìm mentor ngay</a>
                </div>
                <div class="one-metrics">
                    <div><span class="metric-mark"></span><strong>@Model.CompletedSessionCount</strong><small>Buổi học đã ghi nhận</small></div>
                    <div><span class="metric-mark"></span><strong>@Model.MentorCount</strong><small>Mentor đang hoạt động</small></div>
                    <div><span class="metric-mark"></span><strong>@Model.AverageRating.ToString("0.0")/5</strong><small>Đánh giá trung bình</small></div>
                </div>
            </div>

            <div class="one-hero-media">
                <img src="~/images/home-hero-students.png" alt="Sinh viên học 1-1 cùng mentor" />
                <div class="one-float one-float-left"><b>1</b><strong>Học đúng nhu cầu</strong><small>Cá nhân hóa 1-1</small></div>
                <div class="one-float one-float-top"><b>2</b><strong>Lịch rảnh linh hoạt</strong><small>So khớp hai bên</small></div>
                <div class="one-float one-float-right"><b>3</b><strong>Tiến bộ rõ ràng</strong><small>Đánh giá sau buổi học</small></div>
            </div>
        </div>
    </section>

    <section class="one-detail-section" id="quy-trinh">
        <div class="one-section-head centered"><h2>Luồng học 1-1</h2><p>Bám đúng phân tích chức năng của hệ thống.</p></div>
        <div class="process-grid">
            <article><span>01</span><h3>Cập nhật hồ sơ</h3><p>Sinh viên cập nhật kỹ năng, chuyên ngành, mục tiêu học và lịch rảnh.</p></article>
            <article><span>02</span><h3>Tạo yêu cầu</h3><p>Chọn lĩnh vực, mô tả vấn đề và mức độ cần hỗ trợ.</p></article>
            <article><span>03</span><h3>Ghép nối mentor</h3><p>Hệ thống đề xuất mentor theo chuyên môn, lịch rảnh, đánh giá và uy tín.</p></article>
            <article><span>04</span><h3>Học và đánh giá</h3><p>Hai bên lên lịch, học đúng khung giờ đã xác nhận, sinh viên đánh giá sau buổi học.</p></article>
        </div>
    </section>

    <section class="mentor-search-panel" aria-labelledby="mentor-search-title">
        <h2 id="mentor-search-title">Tìm mentor phù hợp</h2>
        <form class="mentor-search-form" asp-controller="Home" asp-action="Hoc11" method="get">
            <label>
                <span>Lĩnh vực</span>
                <select name="linhVucId">
                    <option value="">Tất cả lĩnh vực</option>
                    @foreach (var option in Model.LinhVucOptions)
                    {
                        <option value="@option.Value" selected="@option.Selected">@option.Text</option>
                    }
                </select>
            </label>
            <label><span>Từ khóa</span><input type="search" name="keyword" value="@Model.Keyword" placeholder="VD: Java, SQL, ASP.NET" /></label>
            <button type="submit">Tìm kiếm</button>
        </form>
        <div class="popular-tags">
            <span>Tìm kiếm phổ biến:</span>
            @foreach (var tag in Model.PopularTags)
            {
                <a asp-controller="Home" asp-action="Hoc11" asp-route-keyword="@tag" asp-fragment="mentor-goi-y">@tag</a>
            }
        </div>
    </section>

    <section class="one-feature-strip" aria-label="Tính năng học 1-1">
        <article><span class="blue">AI</span><div><h3>Gợi ý thông minh</h3><p>Đề xuất mentor dựa trên lĩnh vực, chuyên môn, uy tín, đánh giá và lịch rảnh.</p></div></article>
        <article><span class="green">LR</span><div><h3>Lịch học linh hoạt</h3><p>So khớp lịch rảnh sinh viên và mentor trước khi lên lịch.</p></div></article>
        <article><span class="purple">LS</span><div><h3>Lịch sử học tập</h3><p>Hệ thống lưu buổi học đã xác nhận và kết quả đánh giá để theo dõi tiến độ.</p></div></article>
        <article><span class="orange">DG</span><div><h3>Đánh giá mentor</h3><p>Sinh viên đánh giá sau buổi học để cập nhật điểm uy tín.</p></div></article>
        <article><span class="pink">LS</span><div><h3>Lịch sử học tập</h3><p>Theo dõi yêu cầu, ghép nối, lịch học và kết quả học 1-1.</p></div></article>
    </section>

    <section class="mentor-section" id="mentor-goi-y">
        <div class="one-section-head">
            <div>
                <h2>Mentor được gợi ý</h2>
                <p>Dữ liệu lấy trực tiếp từ bảng mentor, chuyên môn, lịch rảnh, đánh giá và ghép nối.</p>
            </div>
            <a asp-controller="YeuCauHoTroHocTaps" asp-action="Create">Tạo yêu cầu</a>
        </div>
        <div class="mentor-list-shell">
            <div class="mentor-grid full-grid">
                @if (Model.MentorGoiY.Count == 0)
                {
                    <article class="mentor-profile-card mentor-empty-card">
                        <h3>Chưa có mentor phù hợp</h3>
                        <p>Hãy thêm mentor, chuyên môn và lịch rảnh trong dữ liệu hệ thống.</p>
                    </article>
                }
                else
                {
                    @for (var i = 0; i < Model.MentorGoiY.Count; i++)
                    {
                        var mentor = Model.MentorGoiY[i];
                        var avatarClass = i % 4 == 1 ? "female" : i % 4 == 2 ? "two" : i % 4 == 3 ? "female two" : "male";
                        <a class="mentor-profile-card mentor-profile-link" asp-controller="Home" asp-action="MentorDetail" asp-route-id="@mentor.MaHuongDan">
                            @if (!string.IsNullOrWhiteSpace(mentor.AnhDaiDien))
                            {
                                <img class="mentor-avatar-img" src="@mentor.AnhDaiDien" alt="@mentor.HoTen" />
                            }
                            else
                            {
                                <span class="mentor-avatar @avatarClass"></span>
                            }
                            <h3>@mentor.HoTen</h3>
                            <p>@mentor.LoaiNguoiHuongDan</p>
                            <div class="rating">Điểm @mentor.DiemDanhGia.ToString("0.0") (@mentor.SoLuotDanhGia) - Uy tín @mentor.DiemUyTin.ToString("0.0")</div>
                            <div class="skill-row">
                                @foreach (var skill in mentor.ChuyenMon)
                                {
                                    <span>@skill</span>
                                }
                            </div>
                            <p>@mentor.MoTaKinhNghiem</p>
                            <p class="mentor-live-data">Lịch rảnh: @mentor.TrangThaiLichRanh</p>
                            <footer><small>Đã hỗ trợ @mentor.SoBuoiHoTro buổi</small><strong>Phù hợp @mentor.TyLePhuHop%</strong></footer>
                            <span class="mentor-card-cta">Xem chi tiết và ghép nối</span>
                        </a>
                    }
                }
            </div>
        </div>
    </section>

    <section class="one-resource-rank-grid">
        <div class="one-learning-resources">
            <div class="one-section-head">
                <div>
                    <p class="eyebrow">Tài liệu tích hợp</p>
                    <h2>Tài liệu hỗ trợ theo nhu cầu học</h2>
                </div>
            </div>
            <div class="learning-resource-list">
                <article><span class="doc-icon blue">PDF</span><div><h3>Giáo trình Python cơ bản</h3><p>Dùng cho yêu cầu nhập môn lập trình và xử lý dữ liệu.</p></div><small>Python</small></article>
                <article><span class="doc-icon green">PDF</span><div><h3>Cấu trúc dữ liệu và giải thuật</h3><p>Tài liệu ôn tập trước khi học cùng mentor.</p></div><small>CTDL</small></article>
                <article><span class="doc-icon purple">PPT</span><div><h3>Machine Learning cơ bản</h3><p>Gợi ý cho sinh viên chọn lĩnh vực AI.</p></div><small>AI</small></article>
                <article><span class="doc-icon orange">DOC</span><div><h3>SQL nâng cao</h3><p>Hỗ trợ các yêu cầu về cơ sở dữ liệu.</p></div><small>SQL</small></article>
            </div>
        </div>

        <aside class="one-ranking-panel">
            <div class="one-section-head compact">
                <div>
                    <p class="eyebrow">Xếp hạng tích hợp</p>
                    <h2>Top mentor uy tín</h2>
                </div>
            </div>
            @if (Model.MentorGoiY.Count == 0)
            {
                <p class="ranking-empty">Chưa có dữ liệu xếp hạng mentor.</p>
            }
            else
            {
                var topMentors = Model.MentorGoiY.OrderByDescending(m => m.DiemUyTin).Take(6).ToList();
                <div class="rank-table-lite">
                    @for (var i = 0; i < topMentors.Count; i++)
                    {
                        <div><span>@(i + 1)</span><strong>@topMentors[i].HoTen</strong><small>@string.Join(", ", topMentors[i].ChuyenMon.Take(1))</small><b>@topMentors[i].DiemUyTin.ToString("0.0")</b></div>
                    }
                </div>
            }
        </aside>
    </section>
</main>
