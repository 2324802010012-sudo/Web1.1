@model StudyConnect.ViewModels.SinhVienHoSoViewModel
@{
    ViewData["Title"] = "Cập nhật hồ sơ sinh viên";
    var days = new[]
    {
        (Value: 2, Label: "Thứ 2"),
        (Value: 3, Label: "Thứ 3"),
        (Value: 4, Label: "Thứ 4"),
        (Value: 5, Label: "Thứ 5"),
        (Value: 6, Label: "Thứ 6"),
        (Value: 7, Label: "Thứ 7"),
        (Value: 8, Label: "Chủ nhật")
    };
    var timeSlots = new[]
    {
        (Start: "07:00", End: "09:00", Label: "Sáng sớm"),
        (Start: "09:00", End: "11:00", Label: "Sáng"),
        (Start: "13:30", End: "15:30", Label: "Chiều 1"),
        (Start: "15:30", End: "17:30", Label: "Chiều 2"),
        (Start: "18:00", End: "20:00", Label: "Tối 1"),
        (Start: "20:00", End: "22:00", Label: "Tối 2")
    };
    var presetValues = days.SelectMany(day => timeSlots.Select(slot => $"{day.Value}|{slot.Start}|{slot.End}")).ToHashSet();
    var customSlots = Model.LichRanhDaChon.Where(value => !presetValues.Contains(value)).Distinct().ToList();
    var studyHistory = ViewBag.StudyHistory as List<StudyConnect.Models.LichHoc> ?? [];
    var selectedDays = Model.LichRanhDaChon
        .Select(value => value.Split('|').FirstOrDefault())
        .Where(value => !string.IsNullOrWhiteSpace(value))
        .Distinct()
        .Count();
    var completedHistoryCount = studyHistory.Count(session =>
        session.TrangThai != "Sinh viên vắng"
        && session.TrangThai != "Vắng mặt"
        && session.TrangThai != "Vắng"
        && (session.TrangThai == "Đã học" || session.TrangThai == "Đã hoàn thành" || session.BaoCaoBuoiHoc != null));

    string SlotLabel(string value)
    {
        var parts = value.Split('|');
        if (parts.Length != 3) return value;
        var day = days.FirstOrDefault(d => d.Value.ToString() == parts[0]).Label ?? $"Thứ {parts[0]}";
        return $"{day} • {parts[1]} - {parts[2]}";
    }
}

<main class="study-flow-page">
    <aside class="study-side-nav">
        <a class="role-brand" asp-controller="SinhVien" asp-action="Index">StudyConnect</a>
        <p>Quy trình học 1-1</p>
        <a class="active" asp-controller="SinhVien" asp-action="HoSo">1. Hồ sơ & lịch rảnh</a>
        <a asp-controller="YeuCauHoTroHocTaps" asp-action="Create">2. Tạo yêu cầu</a>
        <a asp-controller="Home" asp-action="Hoc11" asp-fragment="mentor-goi-y">3. Gợi ý mentor</a>
        <a asp-controller="YeuCauHoTroHocTaps" asp-action="Index">4. Ghép nối & lịch học</a>
        <a href="#lich-su-hoc">Lịch sử học</a>
        <a asp-controller="SinhVien" asp-action="Index">Dashboard sinh viên</a>
    </aside>

    <section class="study-flow-main">
        <div class="flow-breadcrumb">Học 1-1 > Cập nhật hồ sơ</div>
        <header class="flow-title">
            <div>
                <h1>Cập nhật hồ sơ học tập</h1>
                <p>Thông tin này là dữ liệu đầu vào để hệ thống gợi ý mentor theo kỹ năng, chuyên ngành, mục tiêu học và lịch rảnh.</p>
            </div>
        </header>

        <section class="flow-card profile-hero-card">
            <div class="profile-hero-copy">
                <p class="eyebrow">Hồ sơ cá nhân hóa</p>
                <h2>Tối ưu hồ sơ để mentor phù hợp xuất hiện đúng lúc</h2>
                <p class="profile-hero-text">Một hồ sơ rõ ràng giúp hệ thống ghép nối nhanh hơn, đồng thời tạo cảm giác chuyên nghiệp khi bạn cần hỗ trợ học tập 1-1.</p>
                <div class="profile-hero-pills">
                    <span>Chuyên ngành</span>
                    <span>Kỹ năng</span>
                    <span>Lịch rảnh</span>
                    <span>Lịch sử học</span>
                </div>
            </div>
            <div class="profile-hero-stats">
                <article>
                    <strong>@Model.LichRanhDaChon.Count</strong>
                    <span>Khung rảnh đã chọn</span>
                </article>
                <article>
                    <strong>@selectedDays</strong>
                    <span>Ngày có lịch học</span>
                </article>
                <article>
                    <strong>@studyHistory.Count</strong>
                    <span>Buổi học đã lưu</span>
                </article>
            </div>
        </section>

        @if (TempData["InfoMessage"] is string info)
        {
            <div class="flow-alert">@info</div>
        }
        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="flow-alert success">@success</div>
        }
        @if (ViewBag.ErrorMessage is string errorMessage)
        {
            <div class="flow-alert error">@errorMessage</div>
        }

        <form asp-action="HoSo" method="post" class="flow-card profile-update-card" novalidate>
            <input type="hidden" asp-for="ReturnUrl" />
            @if (ViewData.ModelState.ErrorCount > 0)
            {
                <div asp-validation-summary="All" class="alert error"></div>
            }

            <div class="flow-section-title"><span>1</span><h2>Thông tin học tập</h2></div>
            <div class="request-grid two">
                <label class="request-field">
                    <span>Mã số sinh viên</span>
                    <input asp-for="Mssv" placeholder="VD: 2324802010012" />
                    <small asp-validation-for="Mssv"></small>
                </label>
                <label class="request-field">
                    <span>Chuyên ngành</span>
                    <input asp-for="ChuyenNganh" placeholder="VD: Công nghệ phần mềm" />
                    <small asp-validation-for="ChuyenNganh"></small>
                </label>
                <label class="request-field">
                    <span>Lớp</span>
                    <input asp-for="Lop" placeholder="VD: D23_TH01" />
                    <small asp-validation-for="Lop"></small>
                </label>
                <label class="request-field">
                    <span>GPA</span>
                    <input asp-for="Gpa" type="text" inputmode="decimal" placeholder="VD: 3.2 hoặc 3,2" />
                    <small asp-validation-for="Gpa"></small>
                </label>
            </div>

            <div class="flow-section-title"><span>2</span><h2>Kỹ năng và mục tiêu</h2></div>
            <label class="request-field">
                <span>Kỹ năng hiện có</span>
                <textarea asp-for="KyNang" rows="4" placeholder="VD: C#, SQL cơ bản, HTML/CSS, tư duy giải thuật..."></textarea>
                <small asp-validation-for="KyNang"></small>
            </label>
            <label class="request-field">
                <span>Mục tiêu học</span>
                <textarea asp-for="MucTieuHoc" rows="4" placeholder="VD: Muốn nắm chắc ASP.NET MVC để hoàn thành đồ án Web 1-1."></textarea>
                <small asp-validation-for="MucTieuHoc"></small>
            </label>

            <div class="flow-section-title"><span>3</span><h2>Lịch rảnh</h2></div>
            <p class="flow-muted">Chọn nhiều khung giờ bạn có thể học 1-1. Hệ thống sẽ dùng dữ liệu này để so khớp với lịch rảnh của mentor.</p>
            <div class="availability-matrix">
                @foreach (var day in days)
                {
                    <section class="availability-day">
                        <h3>@day.Label</h3>
                        @foreach (var slot in timeSlots)
                        {
                            var value = $"{day.Value}|{slot.Start}|{slot.End}";
                            <label class="slot-check compact">
                                <input type="checkbox" name="LichRanhDaChon" value="@value" checked="@(Model.LichRanhDaChon.Contains(value))" />
                                <strong>@slot.Label</strong>
                                <span>@slot.Start - @slot.End</span>
                            </label>
                        }
                    </section>
                }
            </div>

            <section class="custom-slot-box">
                <div>
                    <h3>Thêm khung giờ riêng</h3>
                    <p>Chủ động thêm giờ rảnh khác, ví dụ 19:30 - 21:00 hoặc cuối tuần.</p>
                </div>
                <div class="custom-slot-form">
                    <select id="customSlotDay" aria-label="Chọn ngày">
                        @foreach (var day in days)
                        {
                            <option value="@day.Value">@day.Label</option>
                        }
                    </select>
                    <input id="customSlotStart" type="time" value="19:00" aria-label="Giờ bắt đầu" />
                    <input id="customSlotEnd" type="time" value="21:00" aria-label="Giờ kết thúc" />
                    <button class="btn btn-light" id="addCustomSlot" type="button">Thêm khung giờ</button>
                </div>
                <div class="custom-slot-list" id="customSlotList">
                    @foreach (var slot in customSlots)
                    {
                        <label class="custom-slot-chip">
                            <input type="checkbox" name="LichRanhDaChon" value="@slot" checked />
                            <span>@SlotLabel(slot)</span>
                        </label>
                    }
                </div>
            </section>
            <small class="field-validation-valid" asp-validation-for="LichRanhDaChon"></small>

            <div class="flow-actions">
                <a class="btn btn-light" asp-controller="SinhVien" asp-action="Index">Hủy</a>
                <button class="btn btn-primary" type="submit">Lưu hồ sơ và tiếp tục</button>
            </div>
        </form>

        <section class="flow-card student-history-card" id="lich-su-hoc">
            <div class="history-card-head">
                <div class="flow-section-title"><span>4</span><h2>Lịch sử học 1-1</h2></div>
                <span class="history-card-badge">@completedHistoryCount / @studyHistory.Count hoàn thành</span>
            </div>
            @if (!studyHistory.Any())
            {
                <div class="empty-state compact">
                    <strong>Chưa có buổi học nào</strong>
                    <p>Sau khi ghép nối và lên lịch, lịch sử học sẽ hiển thị tại đây để bạn theo dõi tiến độ.</p>
                </div>
            }
            else
            {
                <div class="student-study-history">
                    @foreach (var session in studyHistory)
                    {
                        var request = session.MaGhepNoiNavigation.MaYeuCauNavigation;
                        var mentor = session.MaGhepNoiNavigation.MaHuongDanNavigation;
                        var absent = session.TrangThai == "Sinh viên vắng" || session.TrangThai == "Vắng mặt" || session.TrangThai == "Vắng";
                        var completed = !absent && (session.TrangThai == "Đã học" || session.TrangThai == "Đã hoàn thành" || session.BaoCaoBuoiHoc != null);
                        var hasReview = session.MaGhepNoiNavigation.DanhGiaHuongDans.Any();
                        var canReview = completed && !hasReview;
                        <article>
                            <time>
                                <strong>@session.NgayHoc.ToString("dd/MM")</strong>
                                <span>@session.GioBatDau.ToString("HH:mm") - @session.GioKetThuc.ToString("HH:mm")</span>
                            </time>
                            <div>
                                <h3>@request.MaLinhVucNavigation.TenLinhVuc</h3>
                                <p>Mentor: @mentor.MaTaiKhoanNavigation.HoTen • @(session.HinhThuc ?? "Linh hoạt") • @(session.DiaDiem ?? session.LinkOnline ?? "Chưa cập nhật địa điểm")</p>
                                @if (session.BaoCaoBuoiHoc != null)
                                {
                                    <small>Báo cáo: @session.BaoCaoBuoiHoc.NoiDungDaHoc</small>
                                }
                            </div>
                            <a class="history-status @(completed ? "done" : "")" asp-controller="YeuCauHoTroHocTaps" asp-action="Details" asp-route-id="@request.MaYeuCau">
                                @(completed ? "Đã học" : session.TrangThai ?? "Đang lên lịch")
                            </a>
                            @if (canReview)
                            {
                                <a class="btn btn-primary" asp-controller="YeuCauHoTroHocTaps" asp-action="Evaluate" asp-route-id="@session.MaGhepNoi">Đánh giá mentor</a>
                            }
                            else if (hasReview)
                            {
                                <span class="history-status done">Đã đánh giá</span>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    </section>
</main>

@section Scripts {
    <script>
        (() => {
            const days = {
                2: "Thứ 2",
                3: "Thứ 3",
                4: "Thứ 4",
                5: "Thứ 5",
                6: "Thứ 6",
                7: "Thứ 7",
                8: "Chủ nhật"
            };
            const list = document.getElementById("customSlotList");
            const addButton = document.getElementById("addCustomSlot");
            if (!list || !addButton) return;

            addButton.addEventListener("click", () => {
                const day = document.getElementById("customSlotDay").value;
                const start = document.getElementById("customSlotStart").value;
                const end = document.getElementById("customSlotEnd").value;
                if (!day || !start || !end || start >= end) {
                    alert("Vui lòng chọn giờ bắt đầu nhỏ hơn giờ kết thúc.");
                    return;
                }

                const value = `${day}|${start}|${end}`;
                if (document.querySelector(`input[name="LichRanhDaChon"][value="${value}"]`)) return;

                const label = document.createElement("label");
                label.className = "custom-slot-chip";
                label.innerHTML = `<input type="checkbox" name="LichRanhDaChon" value="${value}" checked><span>${days[day]} • ${start} - ${end}</span>`;
                list.appendChild(label);
            });
        })();
    </script>
}
