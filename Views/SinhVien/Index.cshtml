@using StudyConnect.Models
@{
    ViewData["Title"] = "Dashboard sinh viên";
    var sinhVien = ViewBag.SinhVien as SinhVien;
    var upcomingSessions = ViewBag.UpcomingSessions as List<LichHoc> ?? [];
    var mentors = ViewBag.MentorSuggestions as List<NguoiHuongDan> ?? [];
    var clbActivities = ViewBag.ClbActivities as List<HoatDongClb> ?? [];
    var notifications = ViewBag.Notifications as List<StudyConnect.ViewModels.DashboardNotificationViewModel> ?? [];
    var unreadNotificationCount = ViewBag.UnreadNotificationCount as int? ?? 0;
    var mentorApplication = ViewBag.MentorApplication as DangKyHuongDan;
    var skills = (sinhVien?.KyNang ?? string.Empty)
        .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Take(5)
        .ToList();
    var availabilityDays = sinhVien?.MaTaiKhoanNavigation.LichRanhs.Select(l => l.Thu).Distinct().ToHashSet() ?? [];
    var clubs = sinhVien?.ThanhVienClbs.Select(t => t.MaClbNavigation.TenClb).Take(2).ToList() ?? [];
}

<main class="student-dashboard-shell">
    <aside class="student-sidebar">
        <a class="student-brand" asp-controller="Home" asp-action="Index">
            <span class="brand-icon"><span></span><span></span><span></span></span>
            <span><strong>StudyConnect</strong><small>Học 1-1 - Kết nối - Phát triển</small></span>
        </a>

        <nav>
            <a class="active" asp-controller="SinhVien" asp-action="Index"> <span class="student-nav-icon home"></span><span>Trang chủ</span></a>
            <p>Học tập 1-1</p>
            <a asp-controller="YeuCauHoTroHocTaps" asp-action="Create"><span class="student-nav-icon request"></span><span>Tạo yêu cầu hỗ trợ</span></a>
            <a asp-controller="Home" asp-action="Hoc11" asp-fragment="mentor-goi-y"><span class="student-nav-icon mentor"></span><span>Gợi ý mentor</span></a>
            <a asp-controller="YeuCauHoTroHocTaps" asp-action="Index"><span class="student-nav-icon calendar"></span><span>Yêu cầu & lịch học</span></a>
            <a asp-controller="YeuCauHoTroHocTaps" asp-action="Index"><span class="student-nav-icon star"></span><span>Đánh giá mentor</span></a>
            <p>Cộng đồng CLB</p>
            <a asp-controller="Home" asp-action="CauLacBo"><span class="student-nav-icon club"></span><span>CLB của tôi</span></a>
            <a asp-controller="Home" asp-action="CauLacBo"><span class="student-nav-icon activity"></span><span>Hoạt động</span></a>
            <a asp-controller="Home" asp-action="CauLacBo"><span class="student-nav-icon vote"></span><span>Bầu Phó chủ nhiệm</span></a>
            <p>Cá nhân</p>
            <a asp-controller="SinhVien" asp-action="HoSo"><span class="student-nav-icon profile"></span><span>Hồ sơ cá nhân</span></a>
            <a asp-controller="SinhVien" asp-action="HoSo"><span class="student-nav-icon skill"></span><span>Kỹ năng & chuyên môn</span></a>
            <a asp-controller="SinhVien" asp-action="HoSo"><span class="student-nav-icon clock"></span><span>Lịch rảnh</span></a>
            <a asp-controller="SinhVien" asp-action="HoSo" asp-fragment="lich-su-hoc"><span class="student-nav-icon calendar"></span><span>Lịch sử học</span></a>
            <a asp-controller="DangKyHuongDans" asp-action="Create"><span class="student-nav-icon mentor"></span><span>Đăng ký làm mentor</span></a>
            <a asp-controller="TaiKhoans" asp-action="Profile"><span class="student-nav-icon settings"></span><span>Cài đặt</span></a>
        </nav>

        <div class="student-support-card">
            <span class="student-support-icon"></span>
            <strong>Trung tâm hỗ trợ</strong>
            <small>FAQ, hướng dẫn sử dụng</small>
        </div>
    </aside>

    <section class="student-workspace">
        <header class="student-topbar">
            <div>
                <h1>Xin chào, <span>@ViewBag.UserName</span></h1>
                <p>@ViewBag.TodayText</p>
            </div>
            <div class="student-top-actions">
                <label class="student-search"><span class="student-search-icon"></span><input type="search" placeholder="Tìm kiếm..." /></label>
                <details class="student-notification-menu">
                    <summary class="student-bell" aria-label="Thông báo">
                        <i></i>
                        @if (unreadNotificationCount > 0)
                        {
                            <b>@unreadNotificationCount</b>
                        }
                    </summary>
                    <div class="student-notification-popover">
                        <div class="student-notification-head">
                            <strong>Thông báo</strong>
                            @if (unreadNotificationCount > 0)
                            {
                                <form asp-controller="SinhVien" asp-action="MarkNotificationsRead" method="post">
                                    <button type="submit">Đánh dấu đã đọc</button>
                                </form>
                            }
                        </div>
                        @if (notifications.Count == 0)
                        {
                            <article><strong>Chưa có thông báo</strong><p>Lịch học và trạng thái mentor sẽ hiển thị tại đây.</p></article>
                        }
                        else
                        {
                            @foreach (var item in notifications.Take(5))
                            {
                                <article class="@item.Tone">
                                    <strong>@item.Title</strong>
                                    <p>@item.Message</p>
                                    @if (!string.IsNullOrWhiteSpace(item.Url))
                                    {
                                        <a href="@item.Url">Xem</a>
                                    }
                                </article>
                            }
                        }
                    </div>
                </details>
                <div class="student-user-chip">
                    <span>@ViewBag.UserName.Substring(0, 1).ToUpper()</span>
                    <div><strong>@ViewBag.UserName</strong><small>Sinh viên</small></div>
                </div>
            </div>
        </header>

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="flow-alert success">@success</div>
        }
        @if (!(ViewBag.DaCapNhatHoSo is bool done && done))
        {
            <div class="flow-alert">Bạn nên cập nhật hồ sơ học tập và lịch rảnh trước khi tạo yêu cầu hỗ trợ 1-1.</div>
        }

        <section class="student-panel student-notification-panel">
            <div class="student-panel-head"><h2>Thông báo của bạn</h2><a asp-controller="YeuCauHoTroHocTaps" asp-action="Index">Xem lịch học</a></div>
            <div class="dashboard-notification-list">
                @if (notifications.Count == 0)
                {
                    <article><strong>Chưa có thông báo mới</strong><p>Lịch học sắp tới và trạng thái đăng ký mentor sẽ hiển thị tại đây.</p></article>
                }
                else
                {
                    @foreach (var item in notifications)
                    {
                        <article class="@item.Tone">
                            <strong>@item.Title</strong>
                            <p>@item.Message</p>
                            @if (!string.IsNullOrWhiteSpace(item.Url))
                            {
                                <a href="@item.Url">Xem</a>
                            }
                        </article>
                    }
                }
            </div>
        </section>

        <section class="student-stat-grid">
            <article><span class="student-stat-icon blue"></span><div><small>Buổi học sắp tới</small><strong>@ViewBag.LichHoc</strong><a asp-controller="YeuCauHoTroHocTaps" asp-action="Index">Xem lịch học</a></div></article>
            <article><span class="student-stat-icon green"></span><div><small>Buổi học đã hoàn thành</small><strong>@ViewBag.BuoiHoanThanh</strong><a asp-controller="YeuCauHoTroHocTaps" asp-action="Index">Xem chi tiết</a></div></article>
            <article><span class="student-stat-icon orange"></span><div><small>Đánh giá đã gửi</small><strong>@ViewBag.DanhGia</strong><a asp-controller="YeuCauHoTroHocTaps" asp-action="Index">Xem đánh giá</a></div></article>
            <article><span class="student-stat-icon purple"></span><div><small>Yêu cầu hỗ trợ</small><strong>@ViewBag.YeuCau</strong><a asp-controller="YeuCauHoTroHocTaps" asp-action="Create">Tạo mới</a></div></article>
        </section>

        <section class="student-dashboard-grid">
            <div class="student-main-column">
                <section class="student-panel">
                    <div class="student-panel-head"><h2>Buổi học sắp tới</h2><a asp-controller="YeuCauHoTroHocTaps" asp-action="Index">Xem tất cả</a></div>
                    <div class="student-session-list">
                        @if (upcomingSessions.Count == 0)
                        {
                            <div class="student-empty-row"><strong>Chưa có lịch học sắp tới</strong><span>Sau khi mentor chấp nhận ghép nối, bạn có thể lên lịch học tại chi tiết yêu cầu.</span></div>
                        }
                        else
                        {
                            @foreach (var session in upcomingSessions)
                            {
                                var mentor = session.MaGhepNoiNavigation.MaHuongDanNavigation;
                                <article>
                                    <time><strong>@session.NgayHoc.ToString("dd/MM")</strong><span>@session.GioBatDau.ToString("HH:mm")</span></time>
                                    <div class="student-mentor-mini"><span>@mentor.MaTaiKhoanNavigation.HoTen.Substring(0, 1).ToUpper()</span><div><strong>@mentor.MaTaiKhoanNavigation.HoTen</strong><small>Mentor - @mentor.DiemDanhGia?.ToString("0.0") sao</small></div></div>
                                    <div><strong>@session.MaGhepNoiNavigation.MaYeuCauNavigation.MaLinhVucNavigation.TenLinhVuc</strong><small>@session.HinhThuc - @session.TrangThai</small></div>
                                    <a asp-controller="YeuCauHoTroHocTaps" asp-action="Details" asp-route-id="@session.MaGhepNoiNavigation.MaYeuCau">Chi tiết</a>
                                </article>
                            }
                        }
                    </div>
                </section>

                <section class="student-panel">
                    <div class="student-panel-head"><div><h2>Gợi ý mentor dành cho bạn</h2><p>Dựa trên chuyên môn, đánh giá và điểm uy tín.</p></div><a asp-controller="Home" asp-action="Hoc11" asp-fragment="mentor-goi-y">Xem tất cả</a></div>
                    <div class="student-mentor-grid">
                        @foreach (var mentor in mentors)
                        {
                            var specialty = mentor.ChuyenMonNguoiHuongDans.Select(c => c.MaLinhVucNavigation.TenLinhVuc).Take(3).ToList();
                            <article>
                                <div class="student-mentor-mini"><span>@mentor.MaTaiKhoanNavigation.HoTen.Substring(0, 1).ToUpper()</span><div><strong>@mentor.MaTaiKhoanNavigation.HoTen</strong><small>Mentor</small></div></div>
                                <div class="rating">Điểm @mentor.DiemDanhGia?.ToString("0.0") (@mentor.SoLuotDanhGia)</div>
                                <div class="student-chip-row">@foreach (var tag in specialty) { <span>@tag</span> }</div>
                                <p>Đã hỗ trợ @mentor.GhepNoiHocTaps.Count buổi</p>
                                <a asp-controller="Home" asp-action="MentorDetail" asp-route-id="@mentor.MaHuongDan">Xem hồ sơ</a>
                            </article>
                        }
                    </div>
                </section>

                <section class="student-help-banner">
                    <div><strong>Bạn cần hỗ trợ môn học nào?</strong><span>Tạo yêu cầu hoặc đăng ký làm mentor nếu bạn muốn hỗ trợ sinh viên khác.</span></div>
                    <div class="student-banner-actions">
                        <a class="btn btn-primary" asp-controller="YeuCauHoTroHocTaps" asp-action="Create">Tạo yêu cầu hỗ trợ</a>
                        <a class="btn btn-light" asp-controller="DangKyHuongDans" asp-action="Create">Đăng ký làm mentor</a>
                    </div>
                </section>
            </div>

            <aside class="student-side-column">
                <section class="student-panel profile-panel">
                    <div class="student-panel-head"><h2>Hồ sơ của bạn</h2><a asp-controller="SinhVien" asp-action="HoSo">Chỉnh sửa</a></div>
                    <div class="student-profile-card">
                        <span>@ViewBag.UserName.Substring(0, 1).ToUpper()</span>
                        <div><strong>@ViewBag.UserName</strong><small>@(sinhVien?.Lop ?? "Sinh viên")</small><small>@(sinhVien?.ChuyenNganh ?? "Chưa cập nhật chuyên ngành")</small></div>
                    </div>
                    <h3>Chuyên môn & kỹ năng</h3>
                    <div class="student-chip-row">
                        @if (skills.Count == 0) { <span>Chưa cập nhật</span> } else { @foreach (var skill in skills) { <span>@skill</span> } }
                    </div>
                    <h3>Lịch rảnh trong tuần</h3>
                    <div class="student-week-row">
                        @foreach (var day in new[] { 2, 3, 4, 5, 6, 7, 8 })
                        {
                            <span class="@(availabilityDays.Contains(day) ? "active" : string.Empty)">@(day == 8 ? "CN" : $"T{day}")</span>
                        }
                    </div>
                    @if (clubs.Count > 0)
                    {
                        <p class="student-club-note">Thành viên: @string.Join(", ", clubs)</p>
                    }
                    <h3>Đăng ký làm mentor</h3>
                    @if (mentorApplication == null)
                    {
                        <p class="student-club-note">Bạn chưa gửi hồ sơ mentor.</p>
                    }
                    else
                    {
                        <p class="student-club-note">@mentorApplication.MaLinhVucNavigation.TenLinhVuc: @mentorApplication.TrangThaiDuyet</p>
                    }
                    <a class="btn btn-light" asp-controller="DangKyHuongDans" asp-action="Create">Mở form mentor</a>
                </section>

                <section class="student-panel">
                    <div class="student-panel-head"><h2>Hoạt động CLB nổi bật</h2><a asp-controller="Home" asp-action="CauLacBo">Xem tất cả</a></div>
                    <div class="student-club-list">
                        @if (clbActivities.Count == 0)
                        {
                            <article><span>CLB</span><div><strong>Chưa có hoạt động</strong><small>Hoạt động CLB sẽ hiển thị tại đây.</small></div><a asp-controller="Home" asp-action="CauLacBo">Khám phá</a></article>
                        }
                        else
                        {
                            @foreach (var activity in clbActivities)
                            {
                                <article><span>@activity.MaClbNavigation.TenClb.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault()</span><div><strong>@activity.TieuDe</strong><small>@activity.ThoiGian?.ToString("dd/MM/yyyy HH:mm")</small></div><a asp-controller="Home" asp-action="CauLacBo">Chi tiết</a></article>
                            }
                        }
                    </div>
                </section>
            </aside>
        </section>
    </section>
</main>

