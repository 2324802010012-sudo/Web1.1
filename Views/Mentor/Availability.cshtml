@model StudyConnect.ViewModels.MentorAvailabilityViewModel
@{
    ViewData["Title"] = "Cập nhật lịch rảnh mentor";
    var currentSlots = ViewBag.CurrentSlots as List<StudyConnect.Models.LichRanh> ?? [];
    var slotGroups = new Dictionary<string, string[]>
    {
        ["Buổi sáng"] = new[] { "08:00|10:00", "10:00|12:00" },
        ["Buổi chiều"] = new[] { "13:30|15:30", "15:30|17:30" },
        ["Buổi tối"] = new[] { "18:00|20:00", "19:00|21:00" }
    };
    string DayName(int day) => day == 8 ? "Chủ nhật" : $"Thứ {day}";
}

<main class="study-flow-page">
    <aside class="study-side-nav">
        <a class="role-brand" asp-controller="Mentor" asp-action="Index">StudyConnect</a>
        <p>Mentor</p>
        <a asp-controller="Mentor" asp-action="Index">Dashboard mentor</a>
        <a class="active" asp-controller="Mentor" asp-action="Availability">Lịch rảnh cá nhân</a>
    </aside>

    <section class="study-flow-main">
        <div class="flow-breadcrumb">Mentor > Lịch rảnh cá nhân</div>
        <header class="flow-title">
            <div>
                <h1>Cập nhật lịch rảnh</h1>
                <p>Lịch rảnh này được dùng để hệ thống gợi ý ghép nối và kiểm tra khi sinh viên lên lịch học.</p>
            </div>
            <a class="btn btn-light" asp-action="Index" asp-fragment="lich-ranh">Quay lại</a>
        </header>

        <form asp-action="Availability" method="post" class="flow-card request-form-card">
            <div asp-validation-summary="ModelOnly" class="alert error"></div>

            <section class="mentor-current-availability">
                <div>
                    <p class="eyebrow">Đang lưu trong hệ thống</p>
                    <h2>Lịch rảnh hiện tại</h2>
                </div>
                @if (currentSlots.Count == 0)
                {
                    <p class="empty-note">Bạn chưa có lịch rảnh. Hãy chọn các khung bên dưới rồi lưu.</p>
                }
                else
                {
                    <div class="student-chip-row">
                        @foreach (var slot in currentSlots)
                        {
                            <span>@DayName(slot.Thu) @slot.GioBatDau.ToString("HH:mm")-@slot.GioKetThuc.ToString("HH:mm")</span>
                        }
                    </div>
                }
            </section>

            <div class="flow-section-title"><span>1</span><h2>Chọn nhanh theo khung phổ biến</h2></div>
            <div class="mentor-availability-picker">
                @foreach (var day in new[] { 2, 3, 4, 5, 6, 7, 8 })
                {
                    <section>
                        <h3>@DayName(day)</h3>
                        @foreach (var group in slotGroups)
                        {
                            <p>@group.Key</p>
                            <div>
                                @foreach (var slot in group.Value)
                                {
                                    var parts = slot.Split('|');
                                    var value = $"{day}|{parts[0]}|{parts[1]}";
                                    <label>
                                        <input type="checkbox" name="LichRanhDaChon" value="@value" checked="@(Model.LichRanhDaChon.Contains(value))" />
                                        <span>@parts[0] - @parts[1]</span>
                                    </label>
                                }
                            </div>
                        }
                    </section>
                }
            </div>
            <small asp-validation-for="LichRanhDaChon" class="field-validation-error"></small>

            <section class="mentor-custom-slot">
                <div class="flow-section-title"><span>2</span><h2>Thêm khung giờ tùy chỉnh</h2></div>
                <p>Nếu lịch của bạn không nằm trong các ô trên, nhập một khung giờ riêng. Khung này sẽ được lưu chung vào bảng lịch rảnh.</p>
                <div class="request-grid three">
                    <label class="request-field">
                        <span>Thứ</span>
                        <select asp-for="ThuTuyChinh">
                            <option value="">Không thêm</option>
                            <option value="2">Thứ 2</option>
                            <option value="3">Thứ 3</option>
                            <option value="4">Thứ 4</option>
                            <option value="5">Thứ 5</option>
                            <option value="6">Thứ 6</option>
                            <option value="7">Thứ 7</option>
                            <option value="8">Chủ nhật</option>
                        </select>
                    </label>
                    <label class="request-field"><span>Giờ bắt đầu</span><input asp-for="GioBatDauTuyChinh" type="time" /></label>
                    <label class="request-field"><span>Giờ kết thúc</span><input asp-for="GioKetThucTuyChinh" type="time" /></label>
                </div>
            </section>

            <div class="schedule-note-box">
                <strong>Lịch này dùng cho ghép nối thật</strong>
                <p>Sau khi lưu, hệ thống dùng các khung giờ này để tính điểm phù hợp mentor, tạo gợi ý lịch rảnh chung và chặn sinh viên đặt lịch ngoài thời gian hai bên cùng rảnh.</p>
            </div>

            <div class="flow-actions">
                <a class="btn btn-light" asp-action="Index" asp-fragment="lich-ranh">Hủy</a>
                <button class="btn btn-primary" type="submit">Lưu lịch rảnh</button>
            </div>
        </form>
    </section>
</main>
