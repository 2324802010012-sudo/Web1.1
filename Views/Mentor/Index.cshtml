@{
    ViewData["Title"] = "Dashboard mentor";
    var ghepNoiList = ViewBag.GhepNoiList as List<StudyConnect.Models.GhepNoiHocTap> ?? [];
    var lichHocList = ViewBag.LichHocList as List<StudyConnect.Models.LichHoc> ?? [];
    var lichRanhList = ViewBag.LichRanhList as List<StudyConnect.Models.LichRanh> ?? [];
    var notifications = ViewBag.Notifications as List<StudyConnect.ViewModels.DashboardNotificationViewModel> ?? [];
    string DayName(int day) => day == 8 ? "Chủ nhật" : $"Thứ {day}";
}

<main class="role-dashboard mentor-dashboard">
    <aside class="role-sidebar">
        <a class="role-brand" asp-controller="Home" asp-action="Index">StudyConnect</a>
        <p>Mentor</p>
        <a class="active" href="#tong-quan">Tổng quan</a>
        <a href="#thong-bao">Thông báo</a>
        <a href="#lich-ranh">Lịch rảnh</a>
        <a href="#yeu-cau-ghep-noi">Yêu cầu ghép nối</a>
        <a href="#lich-hoc">Lịch học</a>
        <a href="#bao-cao">Báo cáo buổi học</a>
        <a asp-controller="TaiKhoans" asp-action="Profile">Hồ sơ cá nhân</a>
    </aside>

    <section class="role-main">
        <header class="role-header mentor-hero-card">
            <div>
                <p class="eyebrow">Đúng vai trò: Mentor</p>
                <h1>Không gian hướng dẫn của @ViewBag.UserName</h1>
                <span>Quản lý lịch rảnh, yêu cầu ghép nối, lịch học, báo cáo buổi học và điểm uy tín theo quy trình học tập 1-1.</span>
            </div>
            <div class="mentor-header-actions">
                <a class="btn btn-primary" asp-controller="Home" asp-action="Hoc11">Xem trang Học 1-1</a>
                <form asp-controller="TaiKhoans" asp-action="Logout" method="post"><button class="btn btn-outline" type="submit">Đăng xuất</button></form>
            </div>
        </header>

        @if (TempData["SuccessMessage"] is string success)
        {
            <div class="flow-alert success">@success</div>
        }

        <section class="role-stats" id="tong-quan">
            <article><small>Ghép nối</small><strong>@ViewBag.GhepNoi</strong><span>Đề xuất / đang học</span></article>
            <article><small>Lịch dạy</small><strong>@ViewBag.LichHoc</strong><span>Sắp diễn ra</span></article>
            <article><small>Báo cáo đã lập</small><strong>@ViewBag.BaoCao</strong><span>Theo dõi tiến độ</span></article>
            <article><small>Đánh giá TB</small><strong>@ViewBag.DanhGia</strong><span>Từ sinh viên</span></article>
            <article><small>Điểm uy tín</small><strong>@ViewBag.UyTin</strong><span>Dùng cho gợi ý</span></article>
            <article><small>Xếp hạng tháng này</small><strong>@(ViewBag.XepHang ?? "--")</strong><span>@(ViewBag.XepHangLinhVuc == null ? "Chưa có hạng theo lĩnh vực" : $"Hạng lĩnh vực #{ViewBag.XepHangLinhVuc}")</span></article>
        </section>

        <section class="role-panel" id="thong-bao">
            <div class="role-panel-head"><h2>Thông báo mentor</h2><strong>@notifications.Count</strong></div>
            <div class="dashboard-notification-list">
                @if (notifications.Count == 0)
                {
                    <article><strong>Không có thông báo mới</strong><p>Yêu cầu ghép nối và lịch dạy sắp tới sẽ hiển thị tại đây.</p></article>
                }
                else
                {
                    @foreach (var item in notifications)
                    {
                        <article class="@item.Tone">
                            <strong>@item.Title</strong>
                            <p>@item.Message</p>
                            @if (!string.IsNullOrWhiteSpace(item.Url))
                            {
                                <a href="@item.Url">Xem</a>
                            }
                        </article>
                    }
                }
            </div>
        </section>

        <section class="mentor-workspace-grid">
            <article class="role-panel" id="ho-so-chuyen-mon">
                <div class="role-panel-head">
                    <div><p class="eyebrow">Hồ sơ mentor</p><h2>Chuyên môn hướng dẫn</h2></div>
                    <a asp-controller="TaiKhoans" asp-action="Profile">Cập nhật hồ sơ</a>
                </div>
                <div class="mentor-profile-summary">
                    <div class="mentor-avatar-large">M</div>
                    <div>
                        <h3>@ViewBag.UserName</h3>
                        <p>Mentor đã được duyệt, có thể nhận yêu cầu hỗ trợ học tập 1-1.</p>
                        <div class="mentor-skill-tags"><span>Chuyên môn đã duyệt</span><span>Lịch rảnh cá nhân</span><span>Báo cáo sau buổi học</span></div>
                    </div>
                </div>
                <div class="mentor-checklist">
                    <div><span></span><strong>Nhận ghép nối</strong><small>Xem chi tiết yêu cầu trước khi chấp nhận hoặc từ chối.</small></div>
                    <div><span></span><strong>Tự đặt lịch rảnh</strong><small>Lịch rảnh dùng để sinh viên lên lịch học phù hợp.</small></div>
                    <div><span></span><strong>Báo cáo buổi học</strong><small>Lưu nội dung đã học để sinh viên đánh giá.</small></div>
                </div>
            </article>

            <article class="role-panel" id="lich-ranh">
                <div class="role-panel-head">
                    <div><p class="eyebrow">Lịch cá nhân</p><h2>Lịch rảnh tuần này</h2></div>
                    <a asp-action="Availability">Cập nhật lịch</a>
                </div>
                <div class="availability-grid">
                    @if (lichRanhList.Count == 0)
                    {
                        <div><strong>Chưa có lịch rảnh</strong><span>Cập nhật để hệ thống đề xuất bạn cho sinh viên.</span></div>
                    }
                    else
                    {
                        @foreach (var slot in lichRanhList)
                        {
                            <div><strong>@DayName(slot.Thu)</strong><span>@slot.GioBatDau.ToString("HH:mm") - @slot.GioKetThuc.ToString("HH:mm")</span></div>
                        }
                    }
                </div>
                <p class="mentor-muted-note">Hệ thống dùng lịch rảnh của mentor và sinh viên để đề xuất lịch học phù hợp sau khi ghép nối được chấp nhận.</p>
            </article>
        </section>

        <section class="role-panel" id="yeu-cau-ghep-noi">
            <div class="role-panel-head"><div><p class="eyebrow">Ghép nối học tập</p><h2>Yêu cầu hỗ trợ cần phản hồi</h2></div></div>
            <div class="mentor-request-board">
                @if (ghepNoiList.Count == 0)
                {
                    <article><span class="request-level normal">Chưa có đề xuất</span><h3>Chưa có yêu cầu ghép nối</h3><p>Khi sinh viên chọn bạn làm mentor, yêu cầu sẽ xuất hiện tại đây.</p></article>
                }
                else
                {
                    @foreach (var match in ghepNoiList)
                    {
                        <article>
                            <span class="request-level @(match.TrangThai == "Đề xuất" ? "urgent" : "normal")">@match.TrangThai</span>
                            <h3>@match.MaYeuCauNavigation.MaLinhVucNavigation.TenLinhVuc</h3>
                            <p>@match.MaYeuCauNavigation.MucTieu</p>
                            <small>Sinh viên: @match.MaYeuCauNavigation.MaSinhVienNavigation.MaTaiKhoanNavigation.HoTen</small>
                            <footer>
                                <small>Phù hợp @match.DiemPhuHop?.ToString("0")%</small>
                                <div>
                                    <a asp-action="Details" asp-route-id="@match.MaGhepNoi">Chi tiết</a>
                                    @if (match.TrangThai == "Đề xuất" || match.TrangThai == "Đã gửi yêu cầu")
                                    {
                                        <form asp-action="AcceptMatch" asp-route-id="@match.MaGhepNoi" method="post"><button type="submit">Chấp nhận</button></form>
                                        <form asp-action="RejectMatch" asp-route-id="@match.MaGhepNoi" method="post"><button class="light" type="submit">Từ chối</button></form>
                                    }
                                </div>
                            </footer>
                        </article>
                    }
                }
            </div>
        </section>

        <section class="mentor-workspace-grid">
            <article class="role-panel" id="lich-hoc">
                <div class="role-panel-head"><div><p class="eyebrow">Lịch dạy 1-1</p><h2>Buổi học sắp tới</h2></div></div>
                <div class="mentor-session-list">
                    @if (lichHocList.Count == 0)
                    {
                        <div><time>--:--<br />--</time><div><strong>Chưa có lịch dạy</strong><small>Sinh viên sẽ lên lịch sau khi bạn chấp nhận ghép nối.</small></div><span>Trống</span></div>
                    }
                    else
                    {
                        @foreach (var session in lichHocList)
                        {
                            <div>
                                <time>@session.GioBatDau.ToString("HH:mm")<br />@session.NgayHoc.ToString("dd/MM")</time>
                                <div><strong>@session.MaGhepNoiNavigation.MaYeuCauNavigation.MaLinhVucNavigation.TenLinhVuc</strong><small>@session.HinhThuc - @session.MaGhepNoiNavigation.MaYeuCauNavigation.MaSinhVienNavigation.MaTaiKhoanNavigation.HoTen</small></div>
                                @if (session.BaoCaoBuoiHoc == null)
                                {
                                    <a asp-action="BaoCao" asp-route-id="@session.MaLichHoc">Lập báo cáo</a>
                                }
                                else
                                {
                                    <span>Đã báo cáo</span>
                                }
                            </div>
                        }
                    }
                </div>
            </article>

            <article class="role-panel" id="bao-cao">
                <div class="role-panel-head"><div><p class="eyebrow">Sau buổi học</p><h2>Báo cáo cần hoàn tất</h2></div></div>
                <div class="report-flow">
                    <div><span>1</span><strong>Nội dung đã học</strong><small>Tóm tắt kiến thức, ví dụ và lỗi đã xử lý.</small></div>
                    <div><span>2</span><strong>Bài tập / hướng học tiếp</strong><small>Giao nhiệm vụ và tài liệu cần ôn lại.</small></div>
                    <div><span>3</span><strong>Mức độ tiếp thu</strong><small>Nhận xét để cập nhật lịch sử học tập.</small></div>
                </div>
            </article>
        </section>
    </section>
</main>
