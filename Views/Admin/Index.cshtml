@using StudyConnect.Models
@using StudyConnect.ViewModels
@{
    ViewData["Title"] = "Quản trị hệ thống";
    var roleStats = ViewBag.RoleStats as Dictionary<string, int> ?? [];
    var recentAccounts = ViewBag.RecentAccounts as List<TaiKhoan> ?? [];
    var chuNhiemAccounts = ViewBag.ChuNhiemAccounts as List<TaiKhoan> ?? [];
    var clubs = ViewBag.Clubs as List<CauLacBo> ?? [];
    var clubManagers = ViewBag.ClubManagers as List<ThanhVienClb> ?? [];
}

<main class="role-dashboard admin-system-dashboard">
    <aside class="role-sidebar">
        <a class="role-brand" asp-controller="Admin" asp-action="Index">StudyConnect</a>
        <p>Quản trị hệ thống</p>
        <a class="active" href="#tong-quan">Tổng quan</a>
        <a asp-controller="TaiKhoans" asp-action="Index">Tài khoản</a>
        <a asp-controller="TaiKhoans" asp-action="Create">Tạo tài khoản</a>
        <a asp-controller="LinhVucHocTaps" asp-action="Index">Danh mục lĩnh vực</a>
        <a href="#phan-quyen">Phân quyền</a>
        <a href="#cap-quyen-clb">Cấp quyền CLB</a>
        <a href="#cau-hinh">Cấu hình</a>
    </aside>

    <section class="role-main">
        <header class="role-header">
            <div>
                <p class="eyebrow">Admin hệ thống</p>
                <h1>Quản trị nền tảng StudyConnect</h1>
                <span>Admin chỉ quản lý tài khoản, phân quyền, danh mục và trạng thái hệ thống. Các nghiệp vụ học 1-1, mentor, CLB thuộc dashboard vai trò tương ứng.</span>
            </div>
            <form asp-controller="TaiKhoans" asp-action="Logout" method="post"><button class="btn btn-outline" type="submit">Đăng xuất</button></form>
        </header>

        <section class="role-stats admin-system-stats" id="tong-quan">
            <article><small>Tổng tài khoản</small><strong>@ViewBag.TongTaiKhoan</strong></article>
            <article><small>Đang hoạt động</small><strong>@ViewBag.TaiKhoanHoatDong</strong></article>
            <article><small>Bị khóa</small><strong>@ViewBag.TaiKhoanBiKhoa</strong></article>
            <article><small>Vai trò hệ thống</small><strong>@ViewBag.TongVaiTro</strong></article>
            <article><small>Danh mục lĩnh vực</small><strong>@ViewBag.LinhVuc</strong></article>
        </section>

        <section class="role-panel" id="phan-quyen">
            <div class="role-panel-head">
                <div>
                    <p class="eyebrow">Tài khoản & phân quyền</p>
                    <h2>Phân bổ người dùng theo vai trò</h2>
                </div>
                <a asp-controller="TaiKhoans" asp-action="Index">Quản lý tài khoản</a>
            </div>
            <div class="admin-role-grid">
                @foreach (var role in AccountRoles.All)
                {
                    var count = roleStats.TryGetValue(role, out var roleCount) ? roleCount : 0;
                    <article>
                        <span>@role[..1]</span>
                        <strong>@AccountRoles.DisplayName(role)</strong>
                        <small>@count tài khoản</small>
                    </article>
                }
            </div>
        </section>

        <section class="role-panel" id="cap-quyen-clb">
            <div class="role-panel-head">
                <div>
                    <p class="eyebrow">Chủ nhiệm CLB</p>
                    <h2>Cấp quyền quản lý nội bộ CLB</h2>
                </div>
                <strong>@clubManagers.Count phân công</strong>
            </div>
            <form asp-action="AssignClubManager" method="post" class="manager-action-form">
                <label><span>Tài khoản</span>
                    <select name="taiKhoanId" required>
                        @foreach (var account in chuNhiemAccounts)
                        {
                            <option value="@account.MaTaiKhoan">@account.HoTen - @account.Email (@AccountRoles.DisplayName(account.VaiTro))</option>
                        }
                    </select>
                </label>
                <label><span>CLB được quản lý</span>
                    <select name="clbId" required>
                        @foreach (var club in clubs)
                        {
                            <option value="@club.MaClb">@club.TenClb</option>
                        }
                    </select>
                </label>
                <button type="submit">Cấp quyền Chủ nhiệm</button>
            </form>

            <div class="manager-member-list">
                @if (!clubManagers.Any())
                {
                    <p class="empty-text">Chưa có Chủ nhiệm CLB nào được gán vào CLB.</p>
                }
                @foreach (var manager in clubManagers)
                {
                    <div class="manager-member-row">
                        <div>
                            <strong>@manager.MaSinhVienNavigation.MaTaiKhoanNavigation.HoTen</strong>
                            <small>@manager.MaSinhVienNavigation.MaTaiKhoanNavigation.Email</small>
                        </div>
                        <span>@manager.MaClbNavigation.TenClb</span>
                        <span>@(manager.TrangThai ?? "Hoạt động")</span>
                    </div>
                }
            </div>
        </section>

        <section class="role-panel">
            <div class="role-panel-head">
                <div>
                    <p class="eyebrow">Tài khoản mới</p>
                    <h2>Người dùng được tạo gần đây</h2>
                </div>
                <a asp-controller="TaiKhoans" asp-action="Create">Tạo tài khoản mới</a>
            </div>
            <div class="admin-account-table">
                <div class="admin-account-head"><span>Người dùng</span><span>Email</span><span>Vai trò</span><span>Trạng thái</span><span>Ngày tạo</span></div>
                @if (!recentAccounts.Any())
                {
                    <p class="empty-text">Chưa có tài khoản nào.</p>
                }
                @foreach (var account in recentAccounts)
                {
                    <div>
                        <strong>@account.HoTen</strong>
                        <span>@account.Email</span>
                        <span>@AccountRoles.DisplayName(account.VaiTro)</span>
                        <em>@(account.TrangThai ?? "Hoạt động")</em>
                        <small>@(account.NgayTao?.ToString("dd/MM/yyyy") ?? "-")</small>
                    </div>
                }
            </div>
        </section>

        <section class="role-panel" id="cau-hinh">
            <div class="role-panel-head">
                <div>
                    <p class="eyebrow">Phạm vi admin</p>
                    <h2>Chức năng quản trị hệ thống</h2>
                </div>
                <strong>@ViewBag.ThongBao thông báo</strong>
            </div>
            <div class="role-feature-grid admin-system-actions">
                <article><span>TK</span><h3>Tài khoản</h3><p>Tạo, sửa, khóa/mở khóa tài khoản và cập nhật vai trò người dùng.</p><a asp-controller="TaiKhoans" asp-action="Index">Mở quản lý</a></article>
                <article><span>VT</span><h3>Vai trò</h3><p>Kiểm soát nhóm quyền: Admin, Sinh viên, Mentor, Cố vấn và Chủ nhiệm CLB.</p><a asp-controller="TaiKhoans" asp-action="Create">Tạo theo vai trò</a></article>
                <article><span>DM</span><h3>Danh mục</h3><p>Quản lý danh mục lĩnh vực học tập dùng chung cho mentor và yêu cầu học 1-1.</p><a asp-controller="LinhVucHocTaps" asp-action="Index">Mở danh mục</a></article>
                <article><span>HT</span><h3>Hệ thống</h3><p>Theo dõi trạng thái tài khoản, thông báo và dữ liệu nền tảng chung.</p><a href="#tong-quan">Xem tổng quan</a></article>
            </div>
        </section>
    </section>
</main>
